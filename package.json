{
  "name": "watershed",
  "version": "0.1.0",
  "homepage": ".",
  "private": true,
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@webgpu/types": "^0.1.64",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "gl-matrix": "^3.4.4",
    "postprocessing": "^6.38.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.168.0",
    "three-stdlib": "^2.36.1",
    "typescript": "^5.9.3",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.13"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "npm run build:wasm && vite build",
    "build_colab": "npm run build:wasm_colab && npm run build:wasm:threads_colab && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual-smoke": "node verification/visual_smoke.mjs",
    "test:visual-smoke:update": "UPDATE_BASELINES=1 node verification/visual_smoke.mjs",
    "test:wasm": "WATERSHED_WASM_INTEGRATION=1 vitest run src/systems/__tests__/WatershedWasm.integration.test.ts",
    "build:wasm": "cd emscripten && bash build.sh",
    "build:wasm_colab": "cd emscripten && bash build_colab.sh",
    "build:wasm:threads": "cd emscripten && bash build.sh --threads",
    "build:wasm:threads_colab": "cd emscripten && bash build_colab.sh --threads",
    "build:wasm:debug": "cd emscripten && bash build.sh --debug"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "pnpm": {
    "overrides": {
      "@dimforge/rapier3d-compat": "0.19.2"
    }
  },
  "devDependencies": {
    "@types/gl-matrix": "^2.4.5",
    "@types/node": "^20.19.32",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.168.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.37.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
